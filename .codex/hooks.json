{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "horus usage check --path . --threshold 90 --hook || exit 0",
            "commandWindows": "if (Get-Command horus -ErrorAction SilentlyContinue) { horus usage check --path . --threshold 90 --hook }; exit 0",
            "timeout": 30,
            "statusMessage": "Checking Horus usage"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "horus usage check --path . --threshold 90 --hook || exit 0",
            "commandWindows": "if (Get-Command horus -ErrorAction SilentlyContinue) { horus usage check --path . --threshold 90 --hook }; exit 0",
            "timeout": 30,
            "statusMessage": "Checking Horus usage"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "horus close --hook || exit 0",
            "commandWindows": "if (Get-Command horus -ErrorAction SilentlyContinue) { horus close --hook }; exit 0",
            "timeout": 30,
            "statusMessage": "Checking Horus closure"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "horus guard-host --hook || exit 0",
            "commandWindows": "if (Get-Command horus -ErrorAction SilentlyContinue) { horus guard-host --hook }; exit 0",
            "timeout": 30,
            "statusMessage": "Checking Horus host safety"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "horus usage guard --target codex --hook || exit 0",
            "commandWindows": "if (Get-Command horus -ErrorAction SilentlyContinue) { horus usage guard --target codex --hook }; exit 0",
            "timeout": 30,
            "statusMessage": "Checking Horus usage guard"
          }
        ]
      }
    ]
  }
}
